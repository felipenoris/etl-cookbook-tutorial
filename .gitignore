# Ambientes virtuais e caches Python
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
dist/

# Lockfiles (padrão adotado neste projeto: não versionar).
# Cargo.lock: esta extensão é uma library (cdylib), e a convenção do Rust é
# não versionar o lock de libraries.
uv.lock
Cargo.lock

# Artefatos de build do Rust / maturin
target/
*.so

# Dados parquet gerados (recrie com: uv run data/generate_data.py --generate)
*.parquet

# Saída de ETL/demos em data/rich (100% gerada; ex.: JSON do exemplos-DuckDB/19),
# mantendo só o .gitkeep que preserva o diretório
data/rich/*
!data/rich/.gitkeep

# Documentação HTML gerada automaticamente (recrie com pdoc; ver exemplos-rust-extension/README.md)
exemplos-rust-extension/docs/

# Arquivos do sistema operacional / editores
.DS_Store
.idea/
.vscode/
